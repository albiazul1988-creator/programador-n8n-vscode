      "id": "node_aggregate",
      "name": "Juntar Todos los Prospectos",
      "type": "n8n-nodes-base.aggregate",
      "typeVersion": 1,
      "position": [2220, 180]
    },
    {
      "parameters": {
        "jsCode": "const data = $input.first().json;\nconst prospectos = data.prospectos || [];\nprospectos.sort((a, b) => (b.rating || 0) - (a.rating || 0));\nconsole.log('======================================');\nconsole.log('  PROSPECCIÓN COMPLETADA');\nconsole.log('======================================');\nconsole.log('Ciudad: Choclana de la Frontera');\nconsole.log('Negocios sin web encontrados: ' + prospectos.length);\nconsole.log('--------------------------------------');\nprospectos.forEach((p, i) => {\n  console.log((i+1) + '. ' + p.negocio);\n  console.log('   Tel: ' + p.telefono);\n  console.log('   Rating: ' + p.rating + ' estrellas');\n  console.log('');\n});\nreturn [{\n  json: {\n    resumen: {\n      ciudad: 'Choclana de la Frontera',\n      fecha: new Date().toLocaleDateString('es-ES'),\n      total_prospectos: prospectos.length,\n      mensaje: 'Se encontraron ' + prospectos.length + ' negocios sin web. Guardados en Google Sheets.'\n    },\n    prospectos: prospectos\n  }\n}];",
        "mode": "runOnceForAllItems"
      },
      "id": "node_summary",
      "name": "Resumen Final de Prospectos",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [2440, 180]
    }
  ],
