    {
      "parameters": {
        "mode": "runOnceForAllItems",
        "jsCode": "const items = $input.all();\nconst now = new Date();\n\nconst pending = items.filter(item => {\n  const estado = (item.json['Estado'] || '').trim();\n  const fechaEnvio = item.json['Fecha Envio'] || '';\n  \n  if (estado !== 'Enviado') return false;\n  \n  if (!fechaEnvio) return false;\n  const parts = fechaEnvio.split('/');\n  if (parts.length !== 3) return false;\n  const sent = new Date(parts[2] + '-' + parts[1] + '-' + parts[0]);\n  const diffDays = (now - sent) / (1000 * 60 * 60 * 24);\n  return diffDays >= 3;\n});\n\nif (pending.length === 0) return [{ json: { noLeads: true } }];\nreturn pending.map(item => ({ json: item.json }));"
      },
