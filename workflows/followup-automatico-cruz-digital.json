    {
      "parameters": {
        "mode": "runOnceForEachItem",
        "jsCode": "const content = $json.message && $json.message.content ? $json.message.content : ($json.text || '');\nconst lines = content.split('\\n');\n\nlet asunto = '';\nlet htmlStart = -1;\n\nfor (let i = 0; i < lines.length; i++) {\n  if (lines[i].startsWith('ASUNTO:')) {\n    asunto = lines[i].replace('ASUNTO:', '').trim();\n  }\n  if (lines[i].startsWith('HTML:')) {\n    htmlStart = i;\n    break;\n  }\n}\n\nlet htmlContent = '';\nif (htmlStart >= 0) {\n  htmlContent = lines.slice(htmlStart + 1).join('\\n').trim();\n  htmlContent = htmlContent.replace(/^```html?\\n?/, '').replace(/\\n?```$/, '');\n}\n\nreturn [{\n  json: {\n    asunto: asunto || 'Seguimiento - Cruz Digital',\n    html: htmlContent || content,\n    correo: $('Preparar Datos Lead').item.json.correo,\n    web: $('Preparar Datos Lead').item.json.web\n  }\n}];"
      },
